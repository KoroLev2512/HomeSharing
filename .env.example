# =============================================================================
# .env.example — copy to .env.local and fill in your values
# =============================================================================

# --- Next.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-32-chars-min

# --- Supabase (existing) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- PostgreSQL (docker-compose local) ---
DATABASE_URL=postgresql://homesharing:homesharing_dev_pw@localhost:5432/homesharing

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_TTL_LISTINGS=300
REDIS_TTL_PROPERTY=600
REDIS_TTL_SESSION=86400

# --- RabbitMQ ---
RABBITMQ_URL=amqp://homesharing:homesharing_dev_pw@localhost:5672/homesharing
RABBITMQ_EXCHANGE=homesharing.events

# --- Yandex Maps ---
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_API_MAX=30

# --- Observability ---
LOG_LEVEL=info
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=change-me-metrics-token

# --- Workers / Cron ---
WORKER_SECRET=change-me-worker-secret
